STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TESSERACT_CMD=/usr/bin/tesseract
PASSING_MARK=40
