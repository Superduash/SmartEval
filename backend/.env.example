APP_NAME=Smart Evaluation Backend
ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/smart_eval
